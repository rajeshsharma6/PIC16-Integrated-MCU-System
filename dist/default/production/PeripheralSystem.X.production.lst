                                               #INCLUDE <adc.inc>
                                           ;   ADCON0 Register
                                           ;	Bit 7: ADON: ADC Enable (1 - Enabled)
                                           ;	Bit 4: ADCS: ADC Clock Selection (0 = Clock supplied from oscillator pin 13)
                                           ;	Bit 2: ADFRMO: ADC results alignment (0 = ADRESH <7:0>, ADRESL <1:0>) LEFT JUSTIFIED       
                                           ;	Bit 0: ADGO: ADC Conversion Status (0 = conversion completed , 1 = Start conversion cycle)

                                           ;   ADPCH: ADC POSITIVE CHANNEL SELECTION REGISTER (000000 = ANA0) 
                                              
                                           ;   ADREF: ADC REFERENCE SELECTION REGISTER 
                                           ;	Bit 1-0: ADPREF:  Positive Voltage Reference  (00 = VDD)
                                           ;	Bit 4: ADNREF:  Negative Voltage Reference (0 = VSS)

                                              
                                               
                                           init_adc
                                           ;   ADCON0 
000001   0141     movlb   0x01                 BANKSEL ADCON0
000002   3080     movlw   0x80                 MOVLW b'10000000'
000003   0093     movwf   0x13                 MOVWF ADCON0
                                               
                                           ;   ADPCH
000004   0141     movlb   0x01                 BANKSEL ADPCH
000005   019e     clrf    0x1e                 CLRF ADPCH
                                               
                                           ;   ADREF
000006   0141     movlb   0x01                 BANKSEL ADREF
000007   019a     clrf    0x1a                 CLRF ADREF
                                               
000008   0008     return                       RETURN
                                               
                                           adc_convert
000009   0141     movlb   0x01                 BANKSEL ADCON0
00000a   1413     bsf     0x13, 0x0            BSF     ADCON0, 0	; Set Bit 0 (ADGO) to 1 to start conversion

                                           adc_conversionCycle
00000b   1813     btfsc   0x13, 0x0            BTFSC ADCON0, 0	; Check if ADC still converting (Is Bit 0 (ADGO) = 1)
00000c   280b     goto    0x000b               GOTO adc_conversionCycle ; yes
                                               
00000d   0141     movlb   0x01                 BANKSEL ADRESH	 ;contains converted 8 Bit ADC value
00000e   080d     movf    0x0d, 0x0            MOVF    ADRESH, W
00000f   00f1     movwf   0x71                 MOVWF ADC_H8BIT	 ;For PWM CCPR2H
000010   080c     movf    0x0c, 0x0            MOVF ADRESL , W
000011   00f2     movwf   0x72                 MOVWF ADC_L2BIT	 ;For PWM CCPR2L

000012   0008     return                       RETURN

                                           adc_4bit
000013   0141     movlb   0x01                 BANKSEL ADRESH	
000014   080d     movf    0x0d, 0x0            MOVF    ADRESH, W
000015   00f0     movwf   0x70                 MOVWF ADC_4BIT
                                               
                                               ; Shift right 4 times (Divide by 16)
000016   36f0     lsrf    0x70, 0x1            lsrf    ADC_4BIT, f      
000017   36f0     lsrf    0x70, 0x1            lsrf    ADC_4BIT, f      
000018   36f0     lsrf    0x70, 0x1            lsrf    ADC_4BIT, f      
000019   36f0     lsrf    0x70, 0x1            lsrf    ADC_4BIT, f
00001a   0008     return                       RETURN
                                               
                                               #INCLUDE <buzzer.inc>
                                           ;   Buzzer Config 
                                           ;   Pin 38 : RB5 
                                           ;   If ADC_4BIT >= 12
                                           ;	RB1: High (Yellow LED ON)
                                           ;	RB5: High 1s, Low 1s
                                               
                                           ;   Driving Circuit
                                           ;   Speaker Resistance = 8ohms , V/R = 625mA
                                           ;   Maximum Pin output current = 25mA, 
                                           ;   NPN Transistor 2N4401: Ic = B x Ib
                                           ;   Ib = (5V - 0.7V) / 1k ? 4.3 mA

                                           ;   Audible Frequencies 20hz- 20Hz
                                           ;   For 4MHz Oscillator, each instruction cycle is 1µs:
                                           ;   Output Sound at 1kHz
                                           ;   Therefore frequency divider -> Period = 1ms
                                           ;   Toggle High: 0.5ms  (500 instruction cycles each)
                                           ;   Toggle Low: 0.5ms  (500 instruction cycles each)
                                               
                                               
                                           ;   Using Timer2 with CCP module for pulse generation in PWM mode

                                           ;   Programmable Prescalar 1:4 
                                           ;   PWM Period = [(T2PR) + 1] x 4 x TOSC x (TMR2 Prescale Value)
                                           ;	0.001s = [(T2PR) +1] x 4 x (1/4,000,000) x (4)
                                           ;   T2PR = 249  
                                               
                                           ;   T2CON REGISTER 
                                           ;	Bit 7: 1 (ON) 
                                           ;	Bit 6-4: 010 (1:4)
                                               
                                           ;    CCP1CON REGISTER 
                                           ;	Bit 7: 1 CCP1 is enabled 
                                           ;	Bit 4: 0 Right Aligned FMT	
                                           ;	Bit 3-0: 1111  PWM Mode	
                                               
                                           ;   PWM DUTY CYLE CCPRxH:CCPRxL (500)
                                           ;    bits 9:8 = 01 7:0 = 1111 0100
                                           ;    CCPR1H = 00000001
                                           ;    CCPR1L = 11110100
                                               
                                           ;    PERIPHERAL PIN SELECT OUTPUT: RxyPPS REGISTER 
                                           ;    RB5PPS Bits 5-0 = 0x09
                                               
                                           ;    T2CLKCON REGISTER
                                           ;    Bit 3-0; 0001 = FOSC/4
                                               
                                           ;   SETUP FOR PWM OPERATION
                                           ;   1. RxyPPS REGISTER -> Route CCP1 to RB5
                                           ;   2. PR2 REGISTER
                                           ;   3. CCPR1H:CCPR1L
                                           ;   4. CCP1CON REGISTER
                                           ;   5. T2CLKCON, T2CON
                                           ;   6. CCP1CON CLR bit 7
                                           ;    
                                               
                                           init_buzzer_PWM
                                               
00001b   017e     movlb   0x3e                 BANKSEL RB5PPS
00001c   3009     movlw   0x09                 MOVLW 0x09
00001d   009d     movwf   0x1d                 MOVWF RB5PPS
                                               
00001e   0145     movlb   0x05                 BANKSEL T2PR
00001f   30f9     movlw   0xf9                 MOVLW D'249'
000020   008d     movwf   0x0d                 MOVWF T2PR
                                               
000021   0146     movlb   0x06                 BANKSEL CCPR1H 
000022   3001     movlw   0x01                 MOVLW B'00000001'
000023   008d     movwf   0x0d                 MOVWF CCPR1H 
                                               
000024   30f4     movlw   0xf4                 MOVLW B'11110100'
000025   008c     movwf   0x0c                 MOVWF CCPR1L
                                               
000026   0146     movlb   0x06                 BANKSEL CCP1CON 
000027   308f     movlw   0x8f                 MOVLW B'10001111' 
000028   008e     movwf   0x0e                 MOVWF CCP1CON
                                               
000029   0145     movlb   0x05                 BANKSEL T2CLKCON
00002a   3001     movlw   0x01                 MOVLW b'00000001'
00002b   0090     movwf   0x10                 MOVWF T2CLKCON
                                               
00002c   0145     movlb   0x05                 BANKSEL T2CON
00002d   30a0     movlw   0xa0                 MOVLW b'10100000'
00002e   008e     movwf   0x0e                 MOVWF T2CON
                                               
00002f   0146     movlb   0x06                 BANKSEL CCP1CON ; Bit 7: 0 CCP1 is disabled by default 
000030   138e     bcf     0x0e, 0x7            BCF CCP1CON, 7
000031   0008     return                       RETURN
                                                
                                           ; 12 = 1100, 13 = 1101, 14 = 1110, 15 = 1111
                                           ; Any number >= 12 will have Bit 3 and Bit 2 set    
                                           check_alarmState
000032   0140     movlb   0x00                 BANKSEL ADC_4BIT
000033   1df0     btfss   0x70, 0x3            BTFSS ADC_4BIT, 3 
000034   2842     goto    0x0042               GOTO alarm_off
                                               
000035   1d70     btfss   0x70, 0x2            BTFSS ADC_4BIT, 2
000036   2842     goto    0x0042               GOTO alarm_off

                                           alarm_on
                                           ;   LED ON
000037   0140     movlb   0x00                 BANKSEL LATB
000038   1497     bsf     0x17, 0x1            BSF     LATB, 1 
                                               
                                           ;   Check if 1 second passed
000039   0140     movlb   0x00                 BANKSEL TIMER_TOGGLE_BUZZER
00003a   1c79     btfss   0x79, 0x0            BTFSS TIMER_TOGGLE_BUZZER , 0   
00003b   283f     goto    0x003f               GOTO buzz_off		; 0
                                               
                                           buzz_on				; 1
00003c   0146     movlb   0x06                 BANKSEL CCP1CON ; Bit 7: 1 CCP1 enabled
00003d   178e     bsf     0x0e, 0x7            BSF CCP1CON, 7
00003e   0008     return                       RETURN

                                           buzz_off    
00003f   0146     movlb   0x06                 BANKSEL CCP1CON 
000040   138e     bcf     0x0e, 0x7            BCF CCP1CON, 7
000041   0008     return                       RETURN
                                               
                                           alarm_off    
                                           ;   LED OFF
000042   0140     movlb   0x00                 BANKSEL LATB
000043   1097     bcf     0x17, 0x1            BCF     LATB, 1 
                                               
000044   0146     movlb   0x06                 BANKSEL CCP1CON ; Bit 7: 0 CCP1 is disabled by default 
000045   138e     bcf     0x0e, 0x7            BCF CCP1CON, 7
                                               
000046   0140     movlb   0x00                 BANKSEL TIMER_TOGGLE_BUZZER
000047   01f9     clrf    0x79                 CLRF TIMER_TOGGLE_BUZZER	    ;reset 
000048   0008     return                       RETURN
                                               
                                               
                                               
                                              


                                               #INCLUDE <config.inc>
                                           ;   PIN ASSIGNMENT
                                           ;   TRISx: Input (1), Output (0)
                                           ;   ANSELx: Analog (1), Digital (0) 
                                           ; PORTA 
                                           ;	RA0 - Input (Analog) : ADC Channel 0
                                           ;	RA4 - Input (Digital): Tachometer (MOVED FROM RC0)

                                           ;   PORTB
                                           ;	RB0 - Output (Digital): Active-low LED (RED) : DIP - ON, ADC - OFF
                                           ;	RB1 - Output (Digital): Active-high LED (YELLOW) : Alarm - ON    
                                           ;	RB2 - Output (Digital): Active-high LED (GREEN) : Transmitting - ON    
                                           ;	RB5 - Output (Dgital): Buzzer
                                           ;   PORTC
                                           ;	
                                           ;	RC1 - Output : PWM fan speed and 7 SEG brightness 
                                           ;	RC2 - Input (Digital): DIP Pin 1 (LSB)
                                           ;	RC3 - Input (Digital): DIP Pin 2  
                                           ;	RC4 - Input (Digital): DIP Pin 3     
                                           ;	RC5 - Input (Digital): DIP Pin 4 (MSB)
                                           ;	RC6 - Output (Digital): UART TX (To USB RXD)
                                           ;	RC7 - Input (Digital): UART RX (From USB TXD)
                                           ;   PORTD
                                           ;	RD0 - Output (Digital): 7-SEG A	
                                           ;	RD1 - Output (Digital): 7-SEG B
                                           ;	RD2 - Output (Digital): 7-SEG C
                                           ;	RD3 - Output (Digital): 7-SEG D
                                           ;	RD4 - Output (Digital): 7-SEG E
                                           ;	RD5 - Output (Digital): 7-SEG F
                                           ;	RD6 - Output (Digital): 7-SEG G
                                           ;	RD7 - Output (Digital): 7-SEG DP
                                           ;   PORTE
                                           ;	RE0 - Input (Digital): Reset
                                           ;	RE1 - Input (Digital): Active-low Control Mode Select
                                               
                                               
                                               
                                           init_ports    
                                           ;   PORTA
000049   0140     movlb   0x00                 BANKSEL TRISA
00004a   3011     movlw   0x11                 MOVLW B'00010001'	; Set RA0, RA4
00004b   0091     movwf   0x11                 MOVWF TRISA
00004c   017e     movlb   0x3e                 BANKSEL ANSELA
00004d   3001     movlw   0x01                 MOVLW B'00000001'    ; RA0=1 (analog), RA4 digital
00004e   00b8     movwf   0x38                 MOVWF ANSELA         ; 

                                           ;   PORT B
00004f   0140     movlb   0x00                 BANKSEL LATB
000050   0197     clrf    0x17                 CLRF LATB
000051   0140     movlb   0x00                 BANKSEL TRISB
000052   0192     clrf    0x12                 CLRF TRISB		; Make all PORTB pins outputs
000053   017e     movlb   0x3e                 BANKSEL ANSELB	
000054   01c3     clrf    0x43                 CLRF ANSELB		; Make all PORTB pins digital
                                               
                                           ;   PORTC
000055   0140     movlb   0x00                 BANKSEL TRISC
000056   30bd     movlw   0xbd                 MOVLW B'10111101'	 ; Set RC1 & RC6 as only Output
000057   0093     movwf   0x13                 MOVWF TRISC
000058   017e     movlb   0x3e                 BANKSEL ANSELC
000059   01ce     clrf    0x4e                 CLRF ANSELC		 ; Make all PORTC pins digital
                                               
                                           ;   PORTD - 7 SEG
00005a   0140     movlb   0x00                 BANKSEL TRISD
00005b   0194     clrf    0x14                 CLRF TRISD		 ; Make all PORTD pins outputs
00005c   017e     movlb   0x3e                 BANKSEL ANSELD
00005d   01d9     clrf    0x59                 CLRF ANSELD		 ; Make all PORTD pins digital
00005e   0140     movlb   0x00                 BANKSEL LATD		    
00005f   0199     clrf    0x19                 CLRF LATD		 ; Turn OFF 7-Seg
                                               
                                           ;   PORTE
000060   0140     movlb   0x00                 BANKSEL TRISE
000061   3003     movlw   0x03                 MOVLW B'00000011'	 ; Set RE0 & RE1 to input
000062   0095     movwf   0x15                 MOVWF TRISE
000063   017e     movlb   0x3e                 BANKSEL ANSELE
000064   01e4     clrf    0x64                 CLRF ANSELE		 ; Make all PORTE pins digital
                                               
000065   0008     return                       RETURN
                                               #INCLUDE <delays.inc>

                                           ;Outer Loop - 1000ms (100*(10,100+3)+2 overhead+2 return)
                                           Delay_1000milli
000066   3064     movlw   0x64                 MOVLW   d'100'          ; 1 cycle
000067   00f5     movwf   0x75                 MOVWF   DELAY_S            ; 1 cycle - Address 0x21 counter
                                           d_outerloop
000068   206c     call    0x006c               CALL    Delay_10milli   ; 10,100us
000069   0bf5     decfsz  0x75, 0x1            DECFSZ  DELAY_S, 1         ; 1 cycle
00006a   2868     goto    0x0068               goto    d_outerloop     ; 2 cycles
00006b   0008     return                       return                  ; 2 cycles
                                           	
