000079   393c     andlw   0x3c                 ANDLW B'00111100'  ; Zero non-DIP bits
00007a   00f3     movwf   0x73                 MOVWF DIP_4BIT
                                               
                                               ; Shift right 2 times
00007b   36f3     lsrf    0x73, 0x1            lsrf    DIP_4BIT, f      
00007c   36f3     lsrf    0x73, 0x1            lsrf    DIP_4BIT, f      
