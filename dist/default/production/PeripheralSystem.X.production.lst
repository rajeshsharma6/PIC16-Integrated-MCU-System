                                               #INCLUDE <fanspeed.inc>
                                           ;   FANSPEED & 7 SEGMENT BRIGHTNESS CONTROL
                                           ;   Pin 16: RC1
                                               
                                           ;    FAN RATED SPEED 4800 +- 15%
                                               
                                           ;   Similar to PWM used for Buzzer circuit 
                                           ;   Using Timer4 with CCP2 module for pulse generation in PWM mode

                                           ;   Programmable Prescalar 1:4 
                                           ;   PWM Period = [(T4PR) + 1] x 4 x TOSC x (TMR2 Prescale Value)
                                           ;	0.001s = [(T4PR) +1] x 4 x (1/4,000,000) x (4)
                                           ;   T4PR = 249  
                                               
                                           ;   T2CON REGISTER 
                                           ;	Bit 7: 1 (ON) 
                                           ;	Bit 6-4: 010 (1:4) Prescaler
                                               
                                               
                                           ;    CCP2CON REGISTER 
                                           ;	Bit 7: 1 CCP2 is enabled 
                                           ;	Bit 4: 1 LEFT!!! Aligned FMT	
                                           ;	Bit 3-0: 1111  PWM Mode	
                                               
                                           ;   PWM DUTY CYLE CCPRxH:CCPRxL (500)
                                           ;    bits 15:8 = 01 7:6 = 1111 0100
                                           ;    CCPR2H = ADRESH
                                           ;    CCPR2L = ADRESL
                                               
                                           ;    PERIPHERAL PIN SELECT OUTPUT: RxyPPS REGISTER 
                                           ;    RC1PPS Bits 5-0 = 0x0A
                                               
                                           ;    T4CLKCON REGISTER
                                           ;    Bit 3-0; 0001 = FOSC/4
                                               
                                               
                                           ;     CCPTMRS0 REGISTER (HANDLES CCP1/TIMER2 AND CCP2/TIMER4)
                                           ;	C3TSETl[5;4] =10	    TACH CCP3 uses timer1
                                           ;	C2TSEL[3:2] = 10      CCP2 uses Timer4
                                           ;	C1TSEL[1:0] = 01    CCP1 uses Timer2
                                               
                                               
                                           ;   SETUP FOR PWM OPERATION
                                           ;   1. RxyPPS REGISTER -> Route CCP2 to RC1
                                           ;   2. PR2 REGISTER
                                           ;   3. CCPR1H:CCPR1L
                                           ;   4. CCP2CON REGISTER
                                           ;   5. T4CLKCON, T4CON
                                           ;   6. CCP2CON CLR bit 7
                                           ;    
                                               
                                           init_fanspeed_PWM
                                               
00007e   017e     movlb   0x3e                 BANKSEL RC1PPS
00007f   300a     movlw   0x0a                 MOVLW 0x0A
000080   00a1     movwf   0x21                 MOVWF RC1PPS
                                               
000081   0145     movlb   0x05                 BANKSEL T4PR
000082   30f9     movlw   0xf9                 MOVLW D'249'
000083   0093     movwf   0x13                 MOVWF T4PR 
                                               
000084   0146     movlb   0x06                 BANKSEL CCP2CON 
000085   309f     movlw   0x9f                 MOVLW B'10011111' 
000086   0092     movwf   0x12                 MOVWF CCP2CON
                                               
000087   0144     movlb   0x04                 BANKSEL CCPTMRS0
000088   3029     movlw   0x29                 MOVLW   B'00101001'     
000089   009e     movwf   0x1e                 MOVWF   CCPTMRS0
                                               
00008a   0145     movlb   0x05                 BANKSEL T4CLKCON
00008b   3001     movlw   0x01                 MOVLW b'00000001'
00008c   0096     movwf   0x16                 MOVWF T4CLKCON
                                               
00008d   0145     movlb   0x05                 BANKSEL T4CON
00008e   30a0     movlw   0xa0                 MOVLW b'10100000'
00008f   0094     movwf   0x14                 MOVWF T4CON
                                               

                                               ;  Set to MAX by default for 1000 milliseconds
                                               ; Necessary since fan startup voltage is 4V    
000090   0146     movlb   0x06                 BANKSEL CCPR2H 
000091   30ff     movlw   0xff                 MOVLW   0xFF            ; 255 = 100% Duty Cycle
000092   0091     movwf   0x11                 MOVWF   CCPR2H 
000093   3000     movlw   0x00                 MOVLW   0x00            ; Low bits 0
000094   0090     movwf   0x10                 MOVWF   CCPR2L
000095   2066     call    0x0066               CALL Delay_1000milli
000096   0008     return                       RETURN
                                                
                                           adjust_fanspeed
