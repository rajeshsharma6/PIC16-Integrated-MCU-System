000098   0871     movf    0x71, 0x0            MOVF    ADC_H8BIT, W
000099   0146     movlb   0x06                 BANKSEL CCPR2H
00009a   0091     movwf   0x11                 MOVWF   CCPR2H

                                               ; <7:6> LSB
00009b   0140     movlb   0x00                 BANKSEL ADC_L2BIT
00009c   0872     movf    0x72, 0x0            MOVF    ADC_L2BIT, W
00009d   0146     movlb   0x06                 BANKSEL CCPR2L
00009e   0090     movwf   0x10                 MOVWF   CCPR2L
00009f   0008     return                       RETURN
                                               
                                               
                                               #INCLUDE <mode.inc>
                                           ;   RE1 - Active-low (High, Low when pressed)


                                            
                                           press_button
