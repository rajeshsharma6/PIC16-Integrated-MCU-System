                      00058     #INCLUDE <timer.inc>
                      00001 ;   Configure Timer1 16-bit for 1s Delay
                      00002 ;   16-bit = 65,536 counts 
                      00003 ;   OSC: 4MHz
                      00004 ;   OSC/4 : 1MHz
                      00005 ;   1:8 Prescalar: 125,000 Hz 
                      00006 ;   Each timer1 increment = 8us
                      00007 ;   Maximum time before overflow = 65,536 × 8µs = 524,288 µs
                      00008 ;   
                      00009 ;   Use 2 x 500,000us counts:
                      00010 ;   500,000us = 62,500 counts
                      00011 ;   Preload timer with 65,536 - 62,500 = 3,036
                      00012 ;   After 2 overflows: 1s 
                      00013 
                      00014 ;   REGISTERS
                      00015 ;    
                      00016 ;   T1CLK
                      00017 ;        Bit 3-0: 0001 (T1CS:FOSC/4)
                      00018 
                      00019 ;   TMR1H:TMR1L (PRELOAD Timer) 
                      00020 ;       TMR1H: 00001011
                      00021 ;       TMR1L: 11011100 
                      00022     
                      00023 ;    PIR4   reset overflow flag
                      00024 ;       Bit 0: 0  (0: No TMR1 overflow occurred, 1: No TMR1 overflow occurred)
                      00025     
                      00026 ;   T1CON
                      00027 ;        Bit 5-4: 11 (1:8 Prescaler)
                      00028 ;        Bit 0: 1 (ON)
                      00029     
                      00030 
                      00031 ;TIMER_OVERFLOW_COUNTER EQU 0x79
                      00032 ;TIMER_TOGGLE EQU 0x7A
                      00033     
                      00034     
0125                  00035 init_timer1
                      00036     
0125   0144           00037     BANKSEL T1CLK       
0126   3001           00038     MOVLW   b'00000001'           
0127   0091           00039     MOVWF   T1CLK
                      00040    
0128   300B           00041     MOVLW   b'00001011' 
0129   008D           00042     MOVWF   TMR1H       
012A   30DC           00043     MOVLW   b'11011100'       
012B   008C           00044     MOVWF   TMR1L      
                      00045     
012C   014E           00046     BANKSEL PIR4        
012D   1010           00047     BCF     PIR4, 0     
