                      00047 
                      00048 ;    SPBRG: 25 = 9600 baud at 4MHz with BRGH=1, BRG16=0
                      00049 ;       SPBRGL = d'25'
                      00050 ;       SPBRGH  = 0
                      00051     
                      00052 ;   TX1STA: TRANSMIT STATUS AND CONTROL REGISTER
                      00053 ;       bit 5: 1 enabled TXEN: Transmit Enable bit
                      00054 ;       bit 4: 0 asynchronous mode
                      00055 ;       bit 2: 1 BRGH: High Baud Rate Select bit
                      00056 
                      00057 ;    RC1STA: RECEIVE STATUS AND CONTROL REGISTER
                      00058 ;       bit 7: 1 enabled SPEN: Serial Port Enable bit  (needed for Tx and Rx to operate)
                      00059     
