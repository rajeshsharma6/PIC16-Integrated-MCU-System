                      00054     #INCLUDE <fanspeed.inc>
                      00001 ;   FANSPEED & 7 SEGMENT BRIGHTNESS CONTROL
                      00002 ;   Pin 16: RC1
                      00003     
                      00004 ;    FAN RATED SPEED 4800 +- 15%
                      00005     
                      00006 ;   Similar to PWM used for Buzzer circuit 
                      00007 ;   Using Timer4 with CCP2 module for pulse generation in PWM mode
                      00008 
                      00009 ;   Programmable Prescalar 1:4 
                      00010 ;   PWM Period = [(T4PR) + 1] x 4 x TOSC x (TMR2 Prescale Value)
                      00011 ;       0.001s = [(T4PR) +1] x 4 x (1/4,000,000) x (4)
                      00012 ;   T4PR = 249  
                      00013     
                      00014 ;   T2CON REGISTER 
                      00015 ;       Bit 7: 1 (ON) 
                      00016 ;       Bit 6-4: 010 (1:4) Prescaler
                      00017     
                      00018     
                      00019 ;    CCP2CON REGISTER 
                      00020 ;       Bit 7: 1 CCP2 is enabled 
                      00021 ;       Bit 4: 1 LEFT!!! Aligned FMT    
                      00022 ;       Bit 3-0: 1111  PWM Mode 
                      00023     
                      00024 ;   PWM DUTY CYLE CCPRxH:CCPRxL (500)
                      00025 ;    bits 15:8 = 01 7:6 = 1111 0100
                      00026 ;    CCPR2H = ADRESH
                      00027 ;    CCPR2L = ADRESL
                      00028     
                      00029 ;    PERIPHERAL PIN SELECT OUTPUT: RxyPPS REGISTER 
                      00030 ;    RC1PPS Bits 5-0 = 0x0A
                      00031     
                      00032 ;    T4CLKCON REGISTER
                      00033 ;    Bit 3-0; 0001 = FOSC/4
                      00034     
                      00035     
                      00036 ;     CCPTMRS0 REGISTER (HANDLES CCP1/TIMER2 AND CCP2/TIMER4)
                      00037 ;       C3TSETl[5;4] =10            TACH CCP3 uses timer1
                      00038 ;       C2TSEL[3:2] = 10      CCP2 uses Timer4
gpasm-1.5.2 #1309 (Jul  2 2017)      main.asm   3-11-2026  01:58:09         PAGE  9


