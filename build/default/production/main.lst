                      00058     
                      00050     #INCLUDE <buzzer.inc>
                      00001 ;   Buzzer Config 
                      00002 ;   Pin 38 : RB5 
                      00003 ;   If ADC_4BIT >= 12
                      00004 ;       RB1: High (Yellow LED ON)
                      00005 ;       RB5: High 1s, Low 1s
                      00006     
                      00007 ;   Driving Circuit
                      00008 ;   Speaker Resistance = 8ohms , V/R = 625mA
                      00009 ;   Maximum Pin output current = 25mA, 
                      00010 ;   NPN Transistor 2N4401: Ic = B x Ib
                      00011 ;   Ib = (5V - 0.7V) / 1k ? 4.3 mA
                      00012 
                      00013 ;   Audible Frequencies 20hz- 20Hz
                      00014 ;   For 4MHz Oscillator, each instruction cycle is 1µs:
                      00015 ;   Output Sound at 1kHz
                      00016 ;   Therefore frequency divider -> Period = 1ms
                      00017 ;   Toggle High: 0.5ms  (500 instruction cycles each)
                      00018 ;   Toggle Low: 0.5ms  (500 instruction cycles each)
                      00019     
                      00020     
                      00021 ;   Using Timer2 with CCP module for pulse generation in PWM mode
                      00022 
                      00023 ;   Programmable Prescalar 1:4 
                      00024 ;   PWM Period = [(T2PR) + 1] x 4 x TOSC x (TMR2 Prescale Value)
                      00025 ;       0.001s = [(T2PR) +1] x 4 x (1/4,000,000) x (4)
                      00026 ;   T2PR = 249  
                      00027     
                      00028 ;   T2CON REGISTER 
                      00029 ;       Bit 7: 1 (ON) 
                      00030 ;       Bit 6-4: 010 (1:4)
                      00031     
                      00032 ;    CCP1CON REGISTER 
                      00033 ;       Bit 7: 1 CCP1 is enabled 
                      00034 ;       Bit 4: 0 Right Aligned FMT      
                      00035 ;       Bit 3-0: 1111  PWM Mode 
                      00036     
                      00037 ;   PWM DUTY CYLE CCPRxH:CCPRxL (500)
                      00038 ;    bits 9:8 = 01 7:0 = 1111 0100
                      00039 ;    CCPR1H = 00000001
gpasm-1.5.2 #1309 (Jul  2 2017)      main.asm   3-11-2026  01:58:09         PAGE  4


LOC    OBJECT CODE    LINE  SOURCE TEXT
  VALUE

                      00040 ;    CCPR1L = 11110100
                      00041     
                      00042 ;    PERIPHERAL PIN SELECT OUTPUT: RxyPPS REGISTER 
                      00043 ;    RB5PPS Bits 5-0 = 0x09
                      00044     
                      00045 ;    T2CLKCON REGISTER
                      00046 ;    Bit 3-0; 0001 = FOSC/4
                      00047     
                      00048 ;   SETUP FOR PWM OPERATION
                      00049 ;   1. RxyPPS REGISTER -> Route CCP1 to RB5
                      00050 ;   2. PR2 REGISTER
                      00051 ;   3. CCPR1H:CCPR1L
                      00052 ;   4. CCP1CON REGISTER
                      00053 ;   5. T2CLKCON, T2CON
                      00054 ;   6. CCP1CON CLR bit 7
                      00055 ;    
                      00056     
001B                  00057 init_buzzer_PWM
                      00058     
001B   017E           00059     BANKSEL RB5PPS
001C   3009           00060     MOVLW 0x09
001D   009D           00061     MOVWF RB5PPS
                      00062     
001E   0145           00063     BANKSEL T2PR
001F   30F9           00064     MOVLW D'249'
0020   008D           00065     MOVWF T2PR
                      00066     
0021   0146           00067     BANKSEL CCPR1H 
0022   3001           00068     MOVLW B'00000001'
0023   008D           00069     MOVWF CCPR1H 
                      00070     
0024   30F4           00071     MOVLW B'11110100'
0025   008C           00072     MOVWF CCPR1L
                      00073     
0026   0146           00074     BANKSEL CCP1CON 
0027   308F           00075     MOVLW B'10001111' 
0028   008E           00076     MOVWF CCP1CON
                      00077     
0029   0145           00078     BANKSEL T2CLKCON
002A   3001           00079     MOVLW b'00000001'
002B   0090           00080     MOVWF T2CLKCON
                      00081     
002C   0145           00082     BANKSEL T2CON
002D   30A0           00083     MOVLW b'10100000'
002E   008E           00084     MOVWF T2CON
                      00085     
002F   0146           00086     BANKSEL CCP1CON ; Bit 7: 0 CCP1 is disabled by default 
0030   138E           00087     BCF CCP1CON, 7
0031   0008           00088     RETURN
                      00089      
                      00090 ; 12 = 1100, 13 = 1101, 14 = 1110, 15 = 1111
                      00091 ; Any number >= 12 will have Bit 3 and Bit 2 set    
0032                  00092 check_alarmState
