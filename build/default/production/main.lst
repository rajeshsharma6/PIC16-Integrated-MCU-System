0014   080D           00049     MOVF    ADRESH, W
0015   00F0           00050     MOVWF ADC_4BIT
                      00051     
                      00052     ; Shift right 4 times (Divide by 16)
0016   36F0           00053     lsrf    ADC_4BIT, f      
0017   36F0           00054     lsrf    ADC_4BIT, f      
0018   36F0           00055     lsrf    ADC_4BIT, f      
