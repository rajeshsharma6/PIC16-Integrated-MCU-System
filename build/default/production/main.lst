                      00009 ;       RB0 - Output (Digital): Active-low LED (RED) : DIP - ON, ADC - OFF
                      00010 ;       RB1 - Output (Digital): Active-high LED (YELLOW) : Alarm - ON    
                      00011 ;       RB2 - Output (Digital): Active-high LED (GREEN) : Transmitting - ON    
                      00012 ;       RB5 - Output (Dgital): Buzzer
                      00013 ;   PORTC
                      00014 ;       
                      00015 ;       RC1 - Output : PWM fan speed and 7 SEG brightness 
                      00016 ;       RC2 - Input (Digital): DIP Pin 1 (LSB)
                      00017 ;       RC3 - Input (Digital): DIP Pin 2  
                      00018 ;       RC4 - Input (Digital): DIP Pin 3     
                      00019 ;       RC5 - Input (Digital): DIP Pin 4 (MSB)
                      00020 ;       RC6 - Output (Digital): UART TX (To USB RXD)
                      00021 ;       RC7 - Input (Digital): UART RX (From USB TXD)
                      00022 ;   PORTD
                      00023 ;       RD0 - Output (Digital): 7-SEG A 
                      00024 ;       RD1 - Output (Digital): 7-SEG B
                      00025 ;       RD2 - Output (Digital): 7-SEG C
                      00026 ;       RD3 - Output (Digital): 7-SEG D
                      00027 ;       RD4 - Output (Digital): 7-SEG E
                      00028 ;       RD5 - Output (Digital): 7-SEG F
                      00029 ;       RD6 - Output (Digital): 7-SEG G
                      00030 ;       RD7 - Output (Digital): 7-SEG DP
