                      00049     #INCLUDE <adc.inc>
                      00001 ;   ADCON0 Register
                      00002 ;       Bit 7: ADON: ADC Enable (1 - Enabled)
                      00003 ;       Bit 4: ADCS: ADC Clock Selection (0 = Clock supplied from oscillator pin 13)
                      00004 ;       Bit 2: ADFRMO: ADC results alignment (0 = ADRESH <7:0>, ADRESL <1:0>) LEFT JUSTIFIED       
                      00005 ;       Bit 0: ADGO: ADC Conversion Status (0 = conversion completed , 1 = Start conversion cycle)
                      00006 
                      00007 ;   ADPCH: ADC POSITIVE CHANNEL SELECTION REGISTER (000000 = ANA0) 
                      00008    
                      00009 ;   ADREF: ADC REFERENCE SELECTION REGISTER 
                      00010 ;       Bit 1-0: ADPREF:  Positive Voltage Reference  (00 = VDD)
                      00011 ;       Bit 4: ADNREF:  Negative Voltage Reference (0 = VSS)
                      00012 
                      00013    
                      00014     
0001                  00015 init_adc
                      00016 ;   ADCON0 
0001   0141           00017     BANKSEL ADCON0
0002   3080           00018     MOVLW b'10000000'
0003   0093           00019     MOVWF ADCON0
                      00020     
                      00021 ;   ADPCH
0004   0141           00022     BANKSEL ADPCH
0005   019E           00023     CLRF ADPCH
                      00024     
                      00025 ;   ADREF
0006   0141           00026     BANKSEL ADREF
0007   019A           00027     CLRF ADREF
                      00028     
0008   0008           00029     RETURN
                      00030     
0009                  00031 adc_convert
0009   0141           00032     BANKSEL ADCON0
000A   1413           00033     BSF     ADCON0, 0   ; Set Bit 0 (ADGO) to 1 to start conversion
                      00034 
000B                  00035 adc_conversionCycle
000B   1813           00036     BTFSC ADCON0, 0     ; Check if ADC still converting (Is Bit 0 (ADGO) = 1)
000C   2???           00037     GOTO adc_conversionCycle ; yes
                      00038     
000D   0141           00039     BANKSEL ADRESH       ;contains converted 8 Bit ADC value
000E   080D           00040     MOVF    ADRESH, W
000F   00F1           00041     MOVWF ADC_H8BIT      ;For PWM CCPR2H
0010   080C           00042     MOVF ADRESL , W
0011   00F2           00043     MOVWF ADC_L2BIT      ;For PWM CCPR2L
                      00044 
0012   0008           00045     RETURN
