                      00004 ;   PULSE COUNTING: 
                      00005 ;   PIN  6: RA4
                      00006 ;   10k? pull-up resistor to +5V to produce clean pulses.
                      00007 ;   The tach signal on RC0 connected to timer3 input via PPS
                      00008 ;   Timer 3 configured as counter, increments by 1 for every rising edge on RC0
                      00009 ;   Integrate with timer1 TIMER_TOGGLE for 1s intervals
                      00010     
                      00011 ;   get_fanSpeed 
                      00012 ;       Detect when TIMER_TOGGLE != 0, 
                      00013 ;       stop timer3, 
                      00014 ;       count copied to pulse_H:pulse_L 
                      00015 ;       restart timer   
                      00016     
                      00017 ;   convert_to_rpm 
                      00018 ;   Revolutions per second = number of pulses counted in 1 second/2
                      00019 ;   Revolutions per minutes = RPS x 60 = pulses counted x 30    
                      00020 ;       This can be done by left shift 5 times (x32) (LSLF and RLF)
                      00021 ;           Returns RPM that is always 2/32 higher 
                      00022 ;       Repeated Addition: Loop 30 times and add value to itself
                      00023     
                      00024     
                      00025 ; CONFIG
                      00026 ;   PPS Routing to clock input T3CKI 
                      00027 ;   REGISTER T3CKIPPS 
                      00028 ;   RA4 = 0x04 
                      00029 ;    
                      00030 ;   REGISTER T3CLK 
                      00031 ;       BIT 3-0 : 0000 T3CKIPPS
                      00032 ;    
                      00033 ;   REGISTER T3CON
                      00034 ;       Bit 5-4: 00 1:1 Prescaler 
                      00035 ;       Bit 2: 0  synchronize external clock input
                      00036 ;       Bit 1: 1 RD16 All 16 bits of Timer1 can be read simultaneously (TMR1H is buffered)
                      00037 ;       Bit 0: 1 ENABLE
                      00038 
                      00039 ;   Reset counter and overflow flag  
                      00040 ;   TMR3H:TMR3L = 0
                      00041     
                      00042 ;   Clear TRM3IF:Timer3 Overflow Interrupt Flag bit PIR4 bit 2
                      00043 ;   Reset Variables  
                      00044 
