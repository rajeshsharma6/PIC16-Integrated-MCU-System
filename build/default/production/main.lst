                      00059     #INCLUDE <uart.inc>
                      00001 ; Transmission: 
                      00002 ;  TX1REG (write buffer) to TSR (transmit shift register)
                      00003 ;  TSR takes one bit from TX1REG, adds start and stop bit and?clocks each bit onto the TX pin at baud ra
                            te 
                      00004     
                      00005 ; Start bit (LOW), STOP bit (HIGH) 
                      00006     
                      00007 ;  Send "RPM=XXXX\r\n" where XXXX is the current RPM value.
                      00008 ;  Called from main loop when TIMER_TOGGLE_UART != 0.
                      00009 ;  Also turns the TX LED (RB2, active-high) on during transmission.
                      00010      
                      00011 ;  COnvert 16 bit RPM to 4 BCD digits 
                      00012 ;  Repeated subtraction  
                      00013 ;    1. Count how many times 1000 fits -> DIGIT_1000
                      00014 ;       Subtract 1000
                      00015 ;       Check if carry flag = 1
                      00016 ;           No: No borrow, increament 
                      00017 ;           Yea: undo last subtraction, decrement
                      00018 ;    2. how many times  100 fits = DIGIT_100
                      00019 ;    3. how many times   10 fits = DIGIT_10
                      00020 ;    4. remainder         = DIGIT_1
                      00021 
                      00022 ; Covert bin to ASCII : Add 0x30    
                      00023     
                      00024 ;   Fosc = 4MHz    
                      00025 ;   SYNC =0
                      00026 ;   high baud rate (BRGH = 1)
                      00027 ;   16-bit BRG (BRG16 = 0) 
                      00028     
                      00029 ; Refer to Table 33-4   
                      00030 ;   Baud Rate: 9600
                      00031 ;   Actual rate 9615
                      00032 ;   % error: 0.16
                      00033 ;   SPBRG: d'25' 
                      00034     
                      00035  
                      00036 ;   PIN CONFIG
                      00037 ;   PIC TX1: RC6 (connected to PC USB-serial adapter RXD)
                      00038 ;   PIC RX1: RC7 (connected to PC USB-serial adapter TXD)
                      00039     
                      00040 ;   REGISTERS
                      00041 
                      00042 ;   PPS Routing  
                      00043 ;   RC6PPS   - PPS output register for RC6
                      00044 ;       set to 0x10 = TX/CK
gpasm-1.5.2 #1309 (Jul  2 2017)      main.asm   3-11-2026  01:58:09         PAGE 18


